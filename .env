# ================================================================================
# AISI Configuration File
# This file contains environment-specific settings and secrets
# 
# IMPORTANT: 
# - This file is in .gitignore (do not commit to version control)
# - Copy from .env.example and fill in your actual values
# - Keep sensitive data (API keys) secure
# ================================================================================

# ============ VITE (Client) ============
VITE_API_BASE_URL=http://localhost:5173
VITE_APP_ENV=development
VITE_APP_DEBUG=false

# ============ AI Provider Configuration ============
# Options: "gemini" | "openrouter"
VITE_AI_PROVIDER=gemini

# Default AI model to use
VITE_AI_MODEL=gemini-2.5-flash

# ============ API Keys ============
# For Gemini: Get your key from https://ai.google.dev
GEMINI_API_KEY=

# For OpenRouter: Get your key from https://openrouter.ai
OPENROUTER_API_KEY=

# ============ Database ============
# Supabase settings
VITE_SUPABASE_URL=https://eejncugeidzkivhcktzf.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable__XBSLblTVHj3VrA6bUW6dg_BkM-kCGi

# Direct database connection (optional)
DATABASE_URL=

# ============ Authentication ============
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# ============ Feature Flags ============
VITE_ENABLE_AUDIT_LOGS=true
VITE_ENABLE_RISK_PREDICTIONS=true
VITE_ENABLE_AI_FEATURES=true

# ============ API Configuration ============
VITE_API_TIMEOUT_MS=30000
VITE_AI_REQUEST_TIMEOUT_MS=60000
VITE_API_RETRY_COUNT=3
VITE_API_RETRY_DELAY_MS=1000

# ============ Risk Engine ============
VITE_RISK_THRESHOLD_LOW=30
VITE_RISK_THRESHOLD_MEDIUM=60
VITE_RISK_THRESHOLD_HIGH=80
VITE_RISK_THRESHOLD_CRITICAL=90

# ============ Logging ============
VITE_LOG_LEVEL=info
