# ================================================================================
# PRODUCTION Environment (.env.production)
# Used by Vercel and production builds
# 
# DO NOT EDIT DIRECTLY
# Set these variables in Vercel Dashboard: Settings → Environment Variables
# 
# ================================================================================

# ============ VITE (Client - Public) ============
VITE_API_BASE_URL=https://your-domain.vercel.app
VITE_APP_ENV=production
VITE_APP_DEBUG=false

# ============ AI Provider Configuration ============
VITE_AI_PROVIDER=gemini
VITE_AI_MODEL=gemini-2.5-flash

# ============ API Keys (Set in Vercel Dashboard) ============
# These should be secret environment variables in Vercel
# GEMINI_API_KEY=xxx
# OPENROUTER_API_KEY=xxx

# ============ Database - Supabase ============
# These are PUBLIC and can be in this file
VITE_SUPABASE_URL=https://eejncugeidzkivhcktzf.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable__XBSLblTVHj3VrA6bUW6dg_BkM-kCGi

# Set in Vercel Dashboard (SECRET)
# DATABASE_URL=postgresql://...

# ============ Authentication (Set in Vercel Dashboard) ============
# JWT_SECRET=xxx

# ============ Feature Flags ============
VITE_ENABLE_AUDIT_LOGS=true
VITE_ENABLE_RISK_PREDICTIONS=true
VITE_ENABLE_AI_FEATURES=true

# ============ API Configuration ============
VITE_API_TIMEOUT_MS=30000
VITE_AI_REQUEST_TIMEOUT_MS=60000
VITE_API_RETRY_COUNT=3
VITE_API_RETRY_DELAY_MS=1000

# ============ Risk Engine ============
VITE_RISK_THRESHOLD_LOW=30
VITE_RISK_THRESHOLD_MEDIUM=60
VITE_RISK_THRESHOLD_HIGH=80
VITE_RISK_THRESHOLD_CRITICAL=90

# ============ Logging ============
VITE_LOG_LEVEL=info
