# ================================================================================
# Environment Configuration
# Copy this file to .env and fill in your actual values
# ================================================================================

# ============ VITE (Client) ============
VITE_API_BASE_URL=http://localhost:5173
VITE_APP_ENV=development
VITE_APP_DEBUG=false

# ============ AI Provider Configuration ============
# Options: "gemini" | "openrouter"
VITE_AI_PROVIDER=gemini

# Default AI model to use
# For Gemini: gemini-2.5-flash
# For OpenRouter: depends on selected provider
VITE_AI_MODEL=gemini-2.5-flash

# Gemini Configuration
GEMINI_API_KEY=your-gemini-api-key-here

# OpenRouter Configuration (supports multiple LLMs)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ============ Database ============
# Supabase settings (get from https://supabase.com)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key-here
DATABASE_URL=postgresql://user:password@localhost:5432/aisi_db

# ============ Authentication ============
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# ============ Feature Flags ============
VITE_ENABLE_AUDIT_LOGS=true
VITE_ENABLE_RISK_PREDICTIONS=true
VITE_ENABLE_AI_FEATURES=true

# ============ API Timeouts & Retries ============
VITE_API_TIMEOUT_MS=30000
VITE_AI_REQUEST_TIMEOUT_MS=60000
VITE_API_RETRY_COUNT=3
VITE_API_RETRY_DELAY_MS=1000

# ============ Risk Engine Thresholds ============
VITE_RISK_THRESHOLD_LOW=30
VITE_RISK_THRESHOLD_MEDIUM=60
VITE_RISK_THRESHOLD_HIGH=80
VITE_RISK_THRESHOLD_CRITICAL=90

# ============ Logging ============
VITE_LOG_LEVEL=info
# Options: "silent" | "error" | "warn" | "info" | "debug"
